	column MonthDay = ```
			
			IF(
			    MONTH('DateTable'[Date]) = 2 && DAY('DateTable'[Date]) = 29,
			    "02-28",                            
			    FORMAT('DateTable'[Date], "MM-DD")
			)
			```
